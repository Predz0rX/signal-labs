# ═══════════════════════════════════════════════════════
# Signal Labs v2 — Environment Configuration
# ═══════════════════════════════════════════════════════

# ── Core (Required) ──
ANTHROPIC_API_KEY=              # Claude API key (anthropic.com)
NEWS_API_KEY=                   # NewsAPI.org key
RESEND_API_KEY=                 # Resend.com email delivery
FROM_EMAIL=reports@signallabs.ai
PORT=3000
BASE_URL=http://localhost:3000

# ── Supabase (Required for persistence) ──
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SIGNAL_LABS_SUPABASE_URL=       # Browser-safe URL
SIGNAL_LABS_SUPABASE_ANON_KEY=  # Browser-safe anon key

# ── Phase 2: Real Data Sources ──
FRED_API_KEY=                   # Federal Reserve Economic Data (fred.stlouisfed.org) — FREE
ALPHA_VANTAGE_API_KEY=          # Alpha Vantage (alphavantage.co) — FREE (25 req/day)
REDDIT_CLIENT_ID=               # Reddit OAuth app (reddit.com/prefs/apps) — FREE
REDDIT_CLIENT_SECRET=
SEC_EDGAR_USER_AGENT=signal-labs contact@signallabs.ai  # Required by SEC (your app name + email)

# ── Fallback LLM (Optional) ──
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:14b

# ── Admin ──
SEED_SECRET=signallabs2026

