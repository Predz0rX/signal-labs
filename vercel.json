{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "lib/**",
          "templates/**",
          "public/**",
          "index.html"
        ],
        "maxDuration": 60
      }
    }
  ],
  "routes": [
    { "src": "/public/(.*)", "dest": "/server.js" },
    { "src": "/(.*)", "dest": "/server.js" }
  ]
}
